# Copiar para .env e ajustar. Alinhar POLL_SHARED_SECRET (e BOT_GATEWAY_SECRET se usares) com backend/.env.

PORT=80
NODE_ENV=production
LOG_LEVEL=info

BOT_SECRET=super-secret-value

ENABLE_CATCHUP=true

# API backend. Produção: https://dogbot.squareweb.app — dev local: http://127.0.0.1:8000
BACKEND_URL=https://dogbot.squareweb.app

# Timeout do fetch ao POST /playlist/shuffle (ms). O servidor responde 202 em segundos; default 60s basta.
# BACKEND_SHUFFLE_TIMEOUT_MS=60000

POLL_SHARED_SECRET=s3cr3t
# BOT_GATEWAY_SECRET=

INTERNAL_API_PORT=80
INTERNAL_API_BIND=0.0.0.0

# SIMULATE_COMMAND_TIMEOUT_MS=120000
# PUPPETEER_HEADLESS=true
